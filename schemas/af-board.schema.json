{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AccelFury af-board.toml v0.1",
  "type": "object",
  "required": ["id", "name", "vendor", "fpga"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "vendor": { "type": "string" },
    "fpga": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } },
    "pins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "location": { "type": "string" },
          "function": { "type": "string" },
          "verified": { "type": "boolean" },
          "source": { "type": "string" }
        }
      }
    }
  }
}
